[
  {
    "id": "career-1",
    "title": "Site Engineer",
    "department": "Construction Operations",
    "location": "Nicosia",
    "type": "Full-time",
    "description": {
      "type": "doc",
      "content": [
        {
          "type": "paragraph",
          "content": [
            {
              "type": "text",
              "text": "You will run the daily engineering of one of our live sites in the Nicosia district, setting out, supervising subcontractors, checking quality against the drawings and keeping the programme honest. You report to the Project Manager and work beside a foreman who has probably poured more concrete than anyone you have ever met."
            }
          ]
        },
        {
          "type": "heading",
          "attrs": {
            "level": 3
          },
          "content": [
            {
              "type": "text",
              "text": "Responsibilities"
            }
          ]
        },
        {
          "type": "bulletList",
          "content": [
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "type": "text",
                      "text": "Set out works and verify dimensional control across structural and finishing stages."
                    }
                  ]
                }
              ]
            },
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "type": "text",
                      "text": "Coordinate subcontractors and material deliveries against the two-week lookahead programme."
                    }
                  ]
                }
              ]
            },
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "type": "text",
                      "text": "Prepare inspection and test plans, record quality checks and close out non-conformances."
                    }
                  ]
                }
              ]
            },
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "type": "text",
                      "text": "Produce as-built records, measurement sheets and daily site diaries."
                    }
                  ]
                }
              ]
            },
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "type": "text",
                      "text": "Support the HSE Officer in keeping the site induction, permits and toolbox talks current."
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "heading",
          "attrs": {
            "level": 3
          },
          "content": [
            {
              "type": "text",
              "text": "Requirements"
            }
          ]
        },
        {
          "type": "bulletList",
          "content": [
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "type": "text",
                      "text": "Degree in Civil Engineering and registration with ETEK (or eligibility to register)."
                    }
                  ]
                }
              ]
            },
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "type": "text",
                      "text": "2–5 years of site experience on building or civil works; public-sector projects are a plus."
                    }
                  ]
                }
              ]
            },
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "type": "text",
                      "text": "Confident with total stations, AutoCAD and reading structural drawings without help."
                    }
                  ]
                }
              ]
            },
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "type": "text",
                      "text": "Fluent Greek and working English; a clean driving licence."
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    "isOpen": true,
    "sortOrder": 1
  },
  {
    "id": "career-2",
    "title": "Quantity Surveyor",
    "department": "Commercial",
    "location": "Limassol",
    "type": "Full-time",
    "description": {
      "type": "doc",
      "content": [
        {
          "type": "paragraph",
          "content": [
            {
              "type": "text",
              "text": "Based in our Limassol office, you will own the commercial position of two to three live projects, from tender take-offs through monthly valuations to final account. We price honestly, we measure everything, and we expect you to defend both sides of that discipline."
            }
          ]
        },
        {
          "type": "heading",
          "attrs": {
            "level": 3
          },
          "content": [
            {
              "type": "text",
              "text": "Responsibilities"
            }
          ]
        },
        {
          "type": "bulletList",
          "content": [
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "type": "text",
                      "text": "Prepare bills of quantities, tender pricing and subcontract enquiries."
                    }
                  ]
                }
              ]
            },
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "type": "text",
                      "text": "Produce monthly valuations, cost reports and cash-flow forecasts for project reviews."
                    }
                  ]
                }
              ]
            },
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "type": "text",
                      "text": "Administer subcontract accounts: orders, variations, payment certificates and final accounts."
                    }
                  ]
                }
              ]
            },
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "type": "text",
                      "text": "Assess and negotiate variations and claims with clients' consultants."
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "heading",
          "attrs": {
            "level": 3
          },
          "content": [
            {
              "type": "text",
              "text": "Requirements"
            }
          ]
        },
        {
          "type": "bulletList",
          "content": [
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "type": "text",
                      "text": "Degree in Quantity Surveying or Civil Engineering; RICS progression supported."
                    }
                  ]
                }
              ]
            },
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "type": "text",
                      "text": "3+ years post-graduate experience with a contractor or consultancy in Cyprus."
                    }
                  ]
                }
              ]
            },
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "type": "text",
                      "text": "Strong command of measurement standards, FIDIC-based contracts and Excel."
                    }
                  ]
                }
              ]
            },
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "type": "text",
                      "text": "Fluent Greek and English, written and spoken."
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    "isOpen": true,
    "sortOrder": 2
  },
  {
    "id": "career-3",
    "title": "HSE Officer",
    "department": "Health, Safety & Environment",
    "location": "Island-wide",
    "type": "Full-time",
    "description": {
      "type": "doc",
      "content": [
        {
          "type": "paragraph",
          "content": [
            {
              "type": "text",
              "text": "You will audit and support safety across all Characom sites, from Nicosia interchanges to Paphos waterfront works. The role travels, expect three to four site days a week, and carries real authority: you can stop any activity on any site, and the directors will back you when you do."
            }
          ]
        },
        {
          "type": "heading",
          "attrs": {
            "level": 3
          },
          "content": [
            {
              "type": "text",
              "text": "Responsibilities"
            }
          ]
        },
        {
          "type": "bulletList",
          "content": [
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "type": "text",
                      "text": "Carry out planned and unannounced site inspections and publish findings within 24 hours."
                    }
                  ]
                }
              ]
            },
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "type": "text",
                      "text": "Maintain risk assessments, method statements and the group safety management system to ISO 45001."
                    }
                  ]
                }
              ]
            },
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "type": "text",
                      "text": "Deliver inductions and toolbox talks; coach foremen on lifting, excavation and work-at-height controls."
                    }
                  ]
                }
              ]
            },
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "type": "text",
                      "text": "Investigate incidents and near-misses, track actions to closure and report monthly statistics."
                    }
                  ]
                }
              ]
            },
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "type": "text",
                      "text": "Liaise with the Department of Labour Inspection during audits and notifications."
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "heading",
          "attrs": {
            "level": 3
          },
          "content": [
            {
              "type": "text",
              "text": "Requirements"
            }
          ]
        },
        {
          "type": "bulletList",
          "content": [
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "type": "text",
                      "text": "Recognised HSE qualification (NEBOSH Construction Certificate or equivalent)."
                    }
                  ]
                }
              ]
            },
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "type": "text",
                      "text": "3+ years in a construction safety role; marine or highways experience valued."
                    }
                  ]
                }
              ]
            },
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "type": "text",
                      "text": "Knowledge of Cypriot safety legislation and EU construction-site directives."
                    }
                  ]
                }
              ]
            },
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "type": "text",
                      "text": "Full driving licence and willingness to travel island-wide."
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    "isOpen": true,
    "sortOrder": 3
  }
]
