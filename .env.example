# ── Site ────────────────────────────────────────────────────────────────────
# Canonical URL of the deployed site (no trailing slash).
NEXT_PUBLIC_SITE_URL=https://characom.example.com

# ── Admin auth (required for /admin) ────────────────────────────────────────
# Random 32+ char secret used to sign admin session JWTs.
#   generate: openssl rand -base64 32
AUTH_SECRET=

# Owner login. ADMIN_PASSWORD_HASH is "scrypt:<salt-b64>:<hash-b64>".
#   generate with: node scripts/hash-password.mjs "your-password"
ADMIN_EMAIL=admin@characom.example.com
ADMIN_PASSWORD_HASH=

# Optional additional editors: comma-separated email:hash pairs, role=editor.
# ADMIN_EDITORS=

# ── GitHub content backend (required in production for the CMS) ─────────────
# Fine-grained PAT with Contents read/write on the repo below.
# When unset, the app reads/writes ./content on the local filesystem
# (perfect for dev; on Vercel the filesystem is read-only, so the admin
# needs these to publish).
GITHUB_TOKEN=
GITHUB_REPO=AmjadRx/Characom-Site
GITHUB_BRANCH=main

# ── Revalidation ────────────────────────────────────────────────────────────
# Secret for the on-demand revalidate endpoint (POST /api/revalidate).
REVALIDATE_SECRET=

# ── Email notifications (optional) ──────────────────────────────────────────
# Resend API key; inquiry notifications are skipped when unset.
RESEND_API_KEY=
INQUIRY_NOTIFY_EMAIL=
